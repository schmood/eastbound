# Eastbound server configuration — copy to .env and edit (never commit .env).

# The one shared family password. This is the entire gate to the journal API,
# so make it long and not guessable. All four of us use the same value.
FAMILY_PASSWORD=change-me-to-a-long-shared-secret

# Port the server listens on (the reverse proxy forwards to this).
PORT=8080

# Where notes (and confirmation PDFs) are stored. Mount this as a volume so it
# survives redeploys. The SQLite file lives at $DATA_DIR/eastbound.db.
DATA_DIR=./data

# Web Push — the daily 9 AM trip-fact notification. Generate a keypair ONCE with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Keep these STABLE; regenerating invalidates everyone's existing subscriptions.
# Leave unset to disable push (the rest of the app still works).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
