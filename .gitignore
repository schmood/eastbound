# dependencies & build output (also covered per-package)
node_modules/
**/node_modules/
**/dist/
**/.vite/

# local env + runtime data
**/.env
!**/.env.example
# the server's runtime data only (SQLite DB + confirmation PDFs). Do NOT broaden
# this to **/data/ — that also matches web/src/data/, the frontend's content layer.
server/data/

# OS / editor cruft
.DS_Store
*.local
